generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String?
  googleId     String?  @unique
  googleToken  String?
  githubId     String?  @unique
  githubToken  String?
  createdAt    DateTime @default(now())
}